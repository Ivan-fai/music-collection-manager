<Window x:Class="Music_collection.LoginWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизація" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E0044"
        xmlns:local="clr-namespace:Music_collection">

    <Grid>
        <Grid x:Name="LoginGrid">
            <StackPanel VerticalAlignment="Top" Background="#2D0066" Height="50" Orientation="Horizontal">
                <TextBlock Text="Менеджер музичної колекції" Foreground="White" 
                   Margin="20,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

            <Border Width="400" Height="311" 
            BorderBrush="White" BorderThickness="2" 
            CornerRadius="30" VerticalAlignment="Center" HorizontalAlignment="Center" Background="Black">

                <StackPanel Margin="30,20" >

                    <DockPanel Margin="0,0,0,30">
                        <TextBlock Text="Авторизація" Foreground="White" 
                           FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="👤" Foreground="White" FontSize="45" DockPanel.Dock="Right" Height="52" Width="49"/>
                    </DockPanel>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Логін" Foreground="White" VerticalAlignment="Center" FontSize="16"/>

                        <Grid Grid.Column="1" Margin="0,5">

                            <TextBox x:Name="LoginInput"
                    Background="Transparent" Foreground="Gray" BorderBrush="White" BorderThickness="1" Padding="5"
                    TextChanged="LoginInput_TextChanged" VerticalContentAlignment="Center"/>

                            <TextBlock x:Name="LoginInputPlaceholder"
                    Text="Login" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Пароль" Foreground="White" VerticalAlignment="Center" FontSize="16"/>
                        <PasswordBox x:Name ="PasswordInput" Grid.Column="1" Background="Transparent" 
                             Foreground="Gray" BorderBrush="White" BorderThickness="1" 
                             Padding="5" VerticalContentAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Забули пароль?" Foreground="LightGray" 
                       FontSize="12" Margin="60,0,0,30" Cursor="Hand"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Вхід" Width="120" Height="37" Margin="10,0"
                        Background="#460697" Foreground="White" FontSize="18" FontWeight="Bold" BorderBrush="White" BorderThickness="1" Click="SignInButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Реєстрація" Width="120" Height="38" Margin="10,0"
                        Background="#460697" Foreground="White" BorderBrush="White" BorderThickness="1" Click="SignUpButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
        <local:RegistrationWindow x:Name="RegistrationWindowController" Visibility="Collapsed"/>
    </Grid>
</Window>