<Window x:Class="Music_collection.EditAlbum"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Music_collection"
        mc:Ignorable="d"
        Title="EditAlbum"  Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E0044" ResizeMode="NoResize">

    <Grid>
        <Border Margin="20" BorderBrush="White" BorderThickness="1" CornerRadius="35">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Змінити альбом" Foreground="White" 
                       FontSize="20" HorizontalAlignment="Center" Margin="0,5,0,10"/>

                <StackPanel Grid.Row="1" Margin="20,0">
                    <TextBox x:Name="AlbumTitleInput" Background="Transparent" Foreground="White" 
                         BorderBrush="White" BorderThickness="1" Margin="0,3" Padding="5" 
                         HorizontalContentAlignment="Center" Tag="Назва альбому"/>

                    <TextBox x:Name="AlbumArtistInput" Background="Transparent" Foreground="White" 
                         BorderBrush="White" BorderThickness="1" Margin="0,3" Padding="5" 
                         HorizontalContentAlignment="Center" Tag="Виконавець"/>

                    <TextBox x:Name="AlbumYearInput" Background="Transparent" Foreground="White" 
                         BorderBrush="White" BorderThickness="1" Margin="0,3" Padding="5" 
                         HorizontalContentAlignment="Center" Tag="Рік виходу"/>

                    <TextBlock Text="Виберіть треки для альбому:" Foreground="White" Margin="0,10,0,5" FontWeight="Bold"/>
                </StackPanel>

                <Border Grid.Row="2" Margin="20,5" BorderBrush="Gray" BorderThickness="1" CornerRadius="10">
                    <ListBox x:Name="TracksSelectionListBox" Background="Transparent" BorderThickness="0" Foreground="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Foreground="White" Margin="5" VerticalContentAlignment="Center"
                                            IsChecked="{Binding IsSelected}" Tag="{Binding Track.Id}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Author}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Title}"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,5">
                    <Button Content="Зберегти" Width="100" Height="30" Margin="10,0" Background="#460697" Foreground="White" Click="SaveButton_Click"/>
                    <Button Content="Скасувати" Width="100" Height="30" Margin="10,0" Background="Transparent" Foreground="White" BorderBrush="White" Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
