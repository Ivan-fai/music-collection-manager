<Window x:Class="Music_collection.AdministratorMainWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Music_collection"
        mc:Ignorable="d"
        Title="Головне меню адміністратора" Height="600" Width="1000"
        Background="#1E0044">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Background="#2D0066">
                <TextBlock Text="Менеджер музичної колекції" Foreground="White" 
                       VerticalAlignment="Center" Margin="20,0" FontSize="18" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Головна сторінка" Foreground="White" Margin="0,0,20,0" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>

        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,5,20,10">

                <Border Width="40" Height="40" CornerRadius="20" 
                Background="#460697" BorderBrush="White" BorderThickness="1">
                    <TextBlock Text="👤" Foreground="White" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                </Border>

                <Button Width="40" Height="40" Margin="15,0,0,0"
                Background="#460697" BorderBrush="White" BorderThickness="1"
                Foreground="White" FontSize="25" Content="+" 
                Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Width="40" Height="40" Margin="15,0,0,0"
                Background="#460697" BorderBrush="White" BorderThickness="1"
                Foreground="White" FontSize="25" Content="×" 
                Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="White" BorderThickness="0,0,0,1" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="75,0,75,0">
                        <DockPanel>
                            <TextBlock Text="Пошук альбому за фільтром:" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="▽" Foreground="White" Margin="5,0" VerticalAlignment="Center"/>
                            <Button Content="пошук" Width="60" Background="#460697" Foreground="White" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBox Text="Введіть назву альбому" Margin="0,5" Background="Transparent" Foreground="Gray" BorderBrush="White" HorizontalContentAlignment="Center"/>
                        <TextBox Text="Введіть рік виходу" Background="Transparent" Foreground="Gray" BorderBrush="White" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="75,0,75,0">
                        <DockPanel>
                            <TextBlock Text="Пошук колекції за фільтром:" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="▽" Foreground="White" Margin="5,0" VerticalAlignment="Center"/>
                            <Button Content="пошук" Width="60" Background="#460697" Foreground="White" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBox Text="Введіть назву колекції" Margin="0,5" Background="Transparent" Foreground="Gray" BorderBrush="White" HorizontalContentAlignment="Center"/>
                        <TextBox Text="Введіть рік виходу" Background="Transparent" Foreground="Gray" BorderBrush="White" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="10" BorderBrush="White" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#460697" Padding="10">
                            <TextBlock Text="Список доступних альбомів" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </Border>
                        <ListBox Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Stretch">
                            <ListBoxItem Padding="5" BorderBrush="Gray" BorderThickness="0,0,0,1">
                                <DockPanel>
                                <Button Content="+" DockPanel.Dock="Right" Width="20" Height="20" Background="Transparent" Foreground="White" BorderBrush="White" Margin="7"/>
                                <Button Content="🖊" DockPanel.Dock="Right" Width="21" Height="20" Background="Transparent" Foreground="White" BorderBrush="White" Margin="7"/>
                                    <TextBlock Text="Альбом 1 (Рік випуску)" Padding="10"/>
                                </DockPanel>
                            </ListBoxItem>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Margin="10" BorderBrush="White" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#460697" Padding="10">
                            <TextBlock Text="Список доступних композицій" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </Border>
                        <ListBox Background="Transparent" BorderThickness="0" Foreground="White" HorizontalContentAlignment="Stretch">
                            <ListBoxItem Padding="5" BorderBrush="Gray" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="+" DockPanel.Dock="Right" Width="20" Height="20" Background="Transparent" Foreground="White" BorderBrush="White"/>
                                <Button Content="🖊" DockPanel.Dock="Right" Width="21" Height="20" Background="Transparent" Foreground="White" BorderBrush="White" Margin="7"/>
                                <TextBlock Text="Композиція 1 (Рік випуску, альбом)" FontSize="11" Padding="10"/>
                                </DockPanel>
                            </ListBoxItem>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Window>
