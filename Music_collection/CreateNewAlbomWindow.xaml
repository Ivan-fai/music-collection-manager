<Window x:Class="Music_collection.AddAlbumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Створити альбом" Height="500" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="#1E0044" ResizeMode="NoResize">

    <Border Margin="15" BorderBrush="White" BorderThickness="1" CornerRadius="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10,15,10,10">
                <TextBlock Text="Створити альбом" Foreground="White" 
                           FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Text="Введіть назву альбому" Background="Transparent" 
                         Foreground="Gray" BorderBrush="White" BorderThickness="1" 
                         Padding="5" HorizontalContentAlignment="Center"/>
                <Separator Background="White" Margin="0,15,0,0" Height="1"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10,5">
                <TextBlock Text="Пошук композиції за фільтром:" Foreground="White" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Text="Введіть рік виходу" Background="Transparent" 
                         Foreground="Gray" BorderBrush="White" Margin="20,5" Padding="5" 
                         HorizontalContentAlignment="Center"/>
                <TextBox Text="Введіть назву композиції" Background="Transparent" 
                         Foreground="Gray" BorderBrush="White" Margin="20,5" Padding="5" 
                         HorizontalContentAlignment="Center"/>
                <Separator Background="White" Margin="0,15,0,0" Height="1"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="30,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#460697" BorderBrush="White" BorderThickness="1,1,1,0">
                    <TextBlock Text="Список доступних композицій" Foreground="White" 
                               TextAlignment="Center" Padding="5" TextWrapping="Wrap"/>
                </Border>

                <Border Grid.Row="1" BorderBrush="White" BorderThickness="1">
                    <ListBox Background="Transparent" BorderThickness="0">
                        <ListBoxItem Foreground="White" Padding="5">
                            <TextBlock Text="Композиція1 (Рік випуску, у якому альбомі)" 
                                       TextWrapping="Wrap" FontSize="12"/>
                        </ListBoxItem>
                    </ListBox>
                </Border>
            </Grid>

            <UniformGrid Grid.Row="3" Columns="2" Margin="20,0,20,20">
                <Button Content="✔" FontSize="30" Background="Transparent" 
                        Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✘" FontSize="30" Background="Transparent" 
                        Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </UniformGrid>

        </Grid>
    </Border>
</Window>