<UserControl x:Class="Music_collection.RegistrationWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Music_collection"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Height="450" Width="800"
             Background="#FF370379">
    <Grid>
        <Border Width="400" Height="350" 
                BorderBrush="White" BorderThickness="2" 
                CornerRadius="30" VerticalAlignment="Center" HorizontalAlignment="Center" Background="Black">

            <StackPanel Margin="30,20">

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="←" FontSize="30" FontWeight="Bold" 
                Foreground="White" Background="Transparent" BorderBrush="Transparent"
                VerticalAlignment="Center" HorizontalAlignment="Left" Cursor="Hand"
                Click="CancelButton_Click"/>

                    <TextBlock Grid.Column="1" Text="Реєстрація" Foreground="White" FontSize="32" 
                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Створіть новий логін та пароль" Foreground="White" 
               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Логін" Foreground="White" VerticalAlignment="Center" FontSize="16"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="LoginInput" Background="Transparent" Foreground="White" 
                                 BorderBrush="White" BorderThickness="1" Padding="5" 
                                 TextChanged="LoginInput_TextChanged" VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="LoginInputPlaceholder" Text="Login" Foreground="Gray" 
                                   Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Пароль" Foreground="White" VerticalAlignment="Center" FontSize="16"/>
                    <PasswordBox x:Name="PasswordInput" Grid.Column="1" Background="Transparent" 
                                 Foreground="White" BorderBrush="White" BorderThickness="1" 
                                 Padding="5" VerticalContentAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Реєстрація" Width="140" Height="38" Margin="10" 
                            Background="#460697" Foreground="White" BorderBrush="White" BorderThickness="1" 
                            FontSize="14" FontWeight="Bold" Click="SignUpButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>