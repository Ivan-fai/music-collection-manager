<Window x:Class="Music_collection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Music_collection"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="900">
    <Grid>
    <Grid x:Name="MainWindowGrid" Visibility="Visible">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="11*"/>
            <ColumnDefinition Width="89*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Background="#2D0066" VerticalAlignment="Center" RenderTransformOrigin="0.502,1.088" Height="50">
            <TextBlock Text="Менеджер музичної колекції" Foreground="White" 
                       Margin="20,5" FontSize="18" FontWeight="Bold" Height="20"/>
            <TextBlock Text="Особиста колекція альбомів" Foreground="White" 
                       Margin="200,0,20,0" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Background="#1E0044">
                <Button Content="⌂" Margin = "20,20,20,20" Click="HomeButton_Click" Height="30" Width="30" FontSize="20" Background="#460697" Foreground="White"/>
                <Button x:Name="UserAddAlbomButton" Content="Add albom" Margin = "20,20,20,20" Click="AddUserAlbumButton_Click" Height="30" Width="60" FontSize="10"/>
                <Button Grid.Column="2" Width="30" Height="30" VerticalAlignment="Center" Background="#460697" BorderBrush="White"
    BorderThickness="1" Foreground="White" FontSize="15" Content="📄" Cursor="Hand" Click="ExportToMSButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Background="#1E0044" Grid.ColumnSpan="2"></StackPanel>

        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
            BorderBrush="Gray"
            BorderThickness="1"
            Margin="20,0,20,10">

                        <StackPanel Background="#1E0044"
                    Orientation="Horizontal"
                    Margin="5">

                            <TextBlock Text="Пошук альбому за фільтром:"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10"/>

                            <TextBlock Text="▽"
                       Foreground="White"
                       VerticalAlignment="Center"/>

                            <Button Content="ПОШУК"
                    Width="80" Foreground="White" Background="#460697"
                    Margin="10" Click="AlbumFilterButton_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
            BorderBrush="Gray"
            BorderThickness="1"
            Margin="20,0,20,20">

                        <Grid Margin="10">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Left"
                        Margin="10,10,0,10" Width="167">

                                <Grid Margin="0,5">

                                    <TextBox x:Name="AlbumTitleInput" Margin="0,5" HorizontalContentAlignment="Center"
                                      Background="Transparent" Foreground="White" BorderBrush="White" BorderThickness="1"
                                      Padding="5" TextChanged="AlbumTitle_TextChanged"/>

                                    <TextBlock x:Name="AlbumTitlePlaceholder"
                                    Text="Введіть назву альбому" Foreground="Gray" Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                                </Grid>


                                <Grid Margin="0,5">

                                    <TextBox x:Name="AlbumYearInput" HorizontalContentAlignment="Center"
                                      Background="Transparent"
                                      Foreground="White"
                                      BorderBrush="White"
                                      BorderThickness="1"
                                      Padding="5"
                                      TextChanged="AlbumYearInput_TextChanged"/>

                                    <TextBlock x:Name="AlbumYearPlaceholder"
                                    Text="Введіть рік виходу альбома"
                                    Foreground="Gray"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="1"
                  Margin="10">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                           Text="Список ваших альбомів"
                           TextAlignment="Center"
                           Foreground="White"
                           Background="#FF460697"
                           Padding="5"/>

                                <ListBox Grid.Row="1"
                         x:Name="ListOfUserAlbums"
                         Background="Transparent"
                         Foreground="White"
                         BorderBrush="Gray"
                         HorizontalContentAlignment="Stretch">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>

                                            <Border BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="5"
                                    Padding="15,5"
                                    Background="#FF460690">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding AlbumTitle}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Margin="0,0,0,5"/>

                                                        <TextBlock Text="{Binding Artist, StringFormat='Artist: {0}'}"
                                                           Foreground="White"
                                                           FontSize="13"
                                                           Margin="0,0,0,5"/>

                                                        <TextBlock Text="{Binding ReleaseYear, StringFormat='Release year: {0}'}"
                                                           Foreground="White"
                                                           FontSize="11"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                                                        <Button x:Name="DeleteAlbumButton" 
                                                        Content="🗑" 
                                                        Width="24" 
                                                        Height="24" 
                                                        Background="Transparent" 
                                                        Foreground="White" 
                                                        BorderBrush="White" 
                                                        Margin="5" 
                                                        Click="DeleteAlbumButton_Click" 
                                                        Tag="{Binding Id}"/>

                                                        <Button Content="🖊"
                                                        Background="Transparent" 
                                                        Foreground="White" 
                                                        BorderBrush="White" 
                                                        Click="EditButton_Click"
                                                        Tag="{Binding}"
                                                        VerticalAlignment="Center"
                                                        Padding="8,4"
                                                        Margin="5,0,0,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsOfficial}" Value="True"/>
                                                                                <Condition Binding="{Binding Source={x:Static local:App.CurrentUser}, Path=IsAdmin}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>

                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
    </Grid>

        <local:UserMainWindow1 x:Name="UserMain1WindowController" Visibility="Collapsed"/>
    </Grid>
</Window>
